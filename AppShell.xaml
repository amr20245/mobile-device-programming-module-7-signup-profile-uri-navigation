<?xml version="1.0" encoding="UTF-8"?>
<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Module7SignupProfile.Views"
    x:Class="Module7SignupProfile.AppShell">

    <!--
        Define the visual hierarchy of the application.  The initial
        ShellContent hosts the SignupPage and assigns the route "SignupPage"
        which can be used for absolute navigation (e.g. "//SignupPage").
        Additional pages are registered via Routing.RegisterRoute() in
        AppShell.xaml.cs.
    -->
    <ShellContent
        Route="SignupPage"
        Title="Sign Up"
        ContentTemplate="{DataTemplate views:SignupPage}" />

</Shell>

<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Module7SignupProfile.Views.ProfilePage"
    Title="Profile"
    BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="40" Spacing="20">
            <!-- Success message -->
            <Label Text="Signup Successful!"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Username display -->
            <Label Text="Username:"
                   FontAttributes="Bold" />
            <Label Text="{Binding Username}" />

            <!-- Email display -->
            <Label Text="Email:"
                   FontAttributes="Bold" />
            <Label Text="{Binding Email}" />

            <!-- Sign‑out button -->
            <Button Text="Sign Out"
                    FontAttributes="Bold"
                    Clicked="OnSignOutClicked" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
